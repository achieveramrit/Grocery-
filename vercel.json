{
  "builds": [
    {
      "src": "./backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "./frontend/build",
      "use": "@vercel/static"
    }
  ],

  
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://amritgrocery.onrender.com/api/:path*" },
    { "source": "/(.*)", "destination": "/" }
  ]


}
